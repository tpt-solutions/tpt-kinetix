# Rust/Cargo
/target
**/*.rs.bk

# Cargo.lock: committed for binary crates / workspace, excluded for pure libraries.
# This workspace contains binaries, so Cargo.lock is tracked (not ignored).

# Fuzz testing
fuzz/corpus/
fuzz/artifacts/

# Large media samples — never commit binary media to the repo
*.mp4
*.mkv
*.mov
*.avi
*.ts
*.flv
*.yuv
*.h264
*.h265
*.av1

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Env / local config
.env
.env.local
