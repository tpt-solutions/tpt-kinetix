[package]
name = "tpt-kinetix-{{codec_name}}-fuzz"
version = "0.0.0"
publish = false
edition = "2021"

[package.metadata]
cargo-fuzz = true

[dependencies]
libfuzzer-sys = "0.4"
tpt-kinetix-{{codec_name}} = { path = ".." }
tpt-kinetix-core = { path = "../../tpt-kinetix-core" }

[[bin]]
name = "fuzz_{{codec_name}}_parser"
path = "fuzz_targets/fuzz_{{codec_name}}_parser.rs"
test = false
doc = false

[workspace]
members = ["."]

[profile.release]
debug = 1
